# Copier ce fichier en .env.local pour du développement local
# Sur Vercel, ajouter ces variables dans Settings > Environment Variables

# URL de connexion Neon (PostgreSQL)
# Récupérable sur https://console.neon.tech > votre projet > Connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Clé secrète pour NextAuth (générer avec: openssl rand -base64 32)
NEXTAUTH_SECRET=votre_cle_secrete_tres_longue_et_aleatoire

# URL de votre site (sur Vercel, c'est automatique en production)
NEXTAUTH_URL=https://votre-site.vercel.app
